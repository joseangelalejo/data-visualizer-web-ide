# ═══════════════════════════════════════════════════════════════
#  .env.example — Copia esto a .env.local y rellena los valores
#  NUNCA subas .env.local a git
# ═══════════════════════════════════════════════════════════════

# JWT — Genera una clave con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# En windows con Powershell (forzando a 64 bytes):
# $bytes = New-Object 'System.Byte[]' 64; [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); $secret = ($bytes | ForEach-Object { $_.ToString('x2') }) -join ''; $secret | Set-Clipboard; Write-Output $secret
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_MUY_LARGA
JWT_EXPIRES_IN=3600

# Base de datos de usuarios
USERS_DB_PATH=./data/users.db

# Orígenes permitidos (CORS) — añade tu dominio en producción
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Entorno
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
